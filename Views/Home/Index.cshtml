<section id="contact" class="py-5 contact-section">
    
    <div class="container">
        <h2 class="fw-bold mb-3 text-center">Get in Touch</h2>

        <div class="row align-items-center">

            <!-- LEFT: IMAGE -->
            <div class="col-md-6 text-center mb-4 contact-img">
                <img src="@Url.Content("~/images/contact.png")" class="img-fluid" alt="contact">
            </div>

            <!-- RIGHT: FORM -->
            <div class="col-md-6 contact-form-box">

                @if (ViewBag.Success != null)
                {
                    <div class="alert alert-success">@ViewBag.Success</div>
                }

                <form id="contactForm" asp-action="SendMessage" method="post" asp-fragment="contact">
                    <input asp-for="Name" class="form-control mb-3" placeholder="Your Name" required />
                    <input asp-for="Email" class="form-control mb-3" placeholder="Your Email" required />
                    <textarea asp-for="Message" class="form-control mb-3" rows="4" placeholder="Your Message" required></textarea>

                     <button id="sendBtn" class="btn btn-primary w-100">
                          <span id="btnText">Send Message</span>
                          <span id="btnSpinner" class="spinner-border spinner-border-sm ms-2"
                                style="display:none;" role="status"></span>
                      </button>

                    <div id="contactLoader" style="display:none; text-align:center; margin-top:10px;">
                        <div class="loader-container">
                            <ul class="loader-box">
                                <li></li>
                                <li></li>
                                <li></li>
                                <li></li>
                                <li></li>
                                <li></li>
                                <li></li>
                                <li></li>
                                <li></li>
                            </ul>
                        </div>
                    </div>

                </form>

                <!-- EXTRA INFO -->
                <div class="row mt-3">

                    <!-- PHONE -->
                    <div class="col-md-6 d-flex align-items-start">
                        <span class="contact-info__icon me-3">
                            <i class="bi bi-telephone-fill"></i>
                        </span>
                        <div>
                            <h6 class="mb-1">+91 97860 86752</h6>
                            <p class="mb-0 text-muted">Mon to Fri 9am to 6pm</p>
                        </div>
                    </div>

                    <!-- EMAIL -->
                    <div class="col-md-6 d-flex align-items-start">
                        <span class="contact-info__icon me-3">
                            <i class="bi bi-envelope-fill"></i>
                        </span>
                        <div>
                            <h6 class="mb-1">kowsisyam@gmail.com</h6>
                            <p class="mb-0 text-muted">Send me your query anytime!</p>
                        </div>
                    </div>

                </div>
            </div>

        </div>
    </div>
</section>

