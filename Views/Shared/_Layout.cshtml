<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - KowsiPortfolio</title>
    <link rel="stylesheet" href="~/KowsiPortfolio.styles.css" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <!-- NAVBAR -->
    <!-- GLOBAL LOADER -->
    <div class="loader" id="loader-fade">
        <div class="loader-container">
            <ul class="loader-box">
                <li></li>
                <li></li>
                <li></li>
                <li></li>
                <li></li>
                <li></li>
                <li></li>
                <li></li>
                <li></li>
            </ul>
        </div>
    </div>
    <nav class="navbar navbar-expand-lg navbar-dark fixed-top">
        <div class="container">
            <a class="navbar-brand fw-bold text-info" href="#">Kowsalya.</a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav">
                <i class="fas fa-bars" id="menuIcon"></i>
            </button>

            <div class="collapse navbar-collapse" id="nav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="#about">About</a></li>
                    <li class="nav-item"><a class="nav-link" href="#skills">Skills</a></li>
                    <li class="nav-item"><a class="nav-link" href="#experience">Experience</a></li>
                    <li class="nav-item"><a class="nav-link" href="#projects">Projects</a></li>
                    <li class="nav-item"><a class="nav-link" href="#contact">Contact</a></li>

                    <li class="nav-item ms-3 d-none d-lg-block">
                        <a href="#contact" class="btn btn-outline-light">Let's Talk</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>


    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    @RenderSection("Footer", required: false)

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/site.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
   
    <!-- FOOTER -->
    <footer class="footer-wrappr">

        <!-- TOP SECTION -->
        <div class="footer-top py-5">
            <div class="container">
                <div class="row align-items-center justify-content-between">

                    <!-- LEFT SIDE -->
                    <div class="col-lg-6 mb-4">
                        <h4 class="fw-bold text-white mb-3">Kowsalya.</h4>

                        <p class="text-light">
                            Full Stack .NET Developer specialized in ASP.NET Core, Web API,
                            SQL Server and Healthcare integrations.
                        </p>

                        <!-- SOCIAL -->
                        <div class="footer-social mt-3">
                            <a href="https://www.linkedin.com/in/kowsi-s-182a88290/"><i class="fab fa-linkedin"></i></a>
                            <a href="https://github.com/Kowsalya397"><i class="fab fa-github"></i></a>
                            <a href="#"><i class="fab fa-twitter"></i></a>
                            <a href="#"><i class="fab fa-instagram"></i></a>
                        </div>
                    </div>

                    <!-- RIGHT SIDE BUTTONS -->
                    <div class="col-lg-6 text-lg-end">
                        <a href="/Home/DownloadResume" class="btn btn-outline-light m-2">Download CV</a>
                        <a href="#contact" class="btn btn-primary m-2">Let's Talk</a>
                    </div>

                </div>
            </div>
        </div>

        <!-- BOTTOM SECTION -->
        <div class="footer-bottom py-3">
            <div class="container">
                <div class="row align-items-center">

                    <!-- LEFT -->
                    <div class="col-md-6 text-center text-md-start">
                        <p class="mb-0 text-light">
                            Copyright ©2026 All rights reserved | This template is made with  by Kowsalya
                        </p>
                    </div>

                    <!-- RIGHT MENU -->
                    <div class="col-md-6 text-center text-md-end">
                        <a href="#about" class="footer-link">About</a>
                        <a href="#skills" class="footer-link">Skills</a>
                        <a href="#projects" class="footer-link">Projects</a>
                        <a href="#contact" class="footer-link">Contact</a>
                    </div>

                </div>
            </div>
        </div>

    </footer>
</body>
</html>
